# PowerBuilding Workout Tracker — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.

# ── Auth ─────────────────────────────────────────────────────────────────
# Signs all JWT tokens. Generate a fresh one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Keep this value secret — if leaked, all user sessions are compromised.
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32

# JWT token lifetime in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ─────────────────────────────────────────────────────────────
# Local dev: uses SQLite (no setup required)
# DATABASE_URL=sqlite:///./workout_tracker.db

# Production (Render PostgreSQL): paste the "Internal Database URL" here
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── App environment ───────────────────────────────────────────────────────
# Set to "production" on Render; leave as "development" locally
ENVIRONMENT=development

# ── AI features (future) ─────────────────────────────────────────────────
# Add your Anthropic API key here when ready to enable AI features
ANTHROPIC_API_KEY=
